#include <iostream>
using namespace std;

int main() {

    int num;

    cout << "Введите число: ";
    cin >> num;

    cout << "Делители числа " << num << ": ";

    for (int i = 1; i <= num; i++) {

        if (num % i == 0) {
            cout << i << " ";
        }
    }

    cout << endl;

    return 0;
}
